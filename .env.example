DATA_MODE=local
PORT=5000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret

# Local PostgreSQL (used when DATA_MODE=local is NOT needed or for dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asmdaproje_db
DB_USER=postgres
DB_PASSWORD=postgres

# Neon / Cloud PostgreSQL (used when DATA_MODE=cloud)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Vercel sets VERCEL=1 automatically — no need to add it manually
